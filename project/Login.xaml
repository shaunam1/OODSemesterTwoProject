<Window x:Class="project.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:project"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800" MinHeight="400" MinWidth="600" WindowStartupLocation="CenterOwner" Background="RosyBrown">
   
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Foreground="Black" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="30" Width="50" Height="50"/>
        <Label Name="lblAppName" Content="My Little Library" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" FontSize="20" VerticalAlignment="Center"></Label>
        <Label Name="lblUsername" Content="Username" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
        <Label Name="lblPassword" Content="Password" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
        <TextBox Name="tbxUsername" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="300" Background="GhostWhite"></TextBox>
        <TextBox Name="tbxPassword" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="300"  Background="GhostWhite"></TextBox>
        <Button Name="btnLogin" Content="Login" Grid.Row="3" Grid.Column="1" Click="btnLogin_Click" Width="200"></Button>
    </Grid>
</Window>
