<Window x:Name="MainWindow1" x:Class="project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:project"
        mc:Ignorable="d"
        Title="Home" Height="450" Width="800" MinHeight="400" MinWidth="600" Loaded="MainWindow1_Loaded">
    <TabControl x:Name="MyControl" TabStripPlacement="Bottom">
        <TabItem x:Name="TabHome">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Home"
                     VerticalAlignment="Center"
                     FontSize="16"
                     Foreground="Black"/>
                </StackPanel>
            </TabItem.Header>
            <Grid Name="myGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="75"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200*"></ColumnDefinition>
                    <ColumnDefinition Width="300*"></ColumnDefinition>
                    <ColumnDefinition Width="300*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"/>
                <TextBlock x:Name="tblkCartCount"  Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,41,0"/>
                <TextBox x:Name="tbxSearch" Grid.Column="1" HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" Text="Search" VerticalAlignment="Center" Width="161" Height="25" GotFocus="tbxSearch_GotFocus" KeyDown="tbxSearch_KeyDown"/>

                <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top" Width="50" Height="50"/>
                <ListBox x:Name="lbxAuthor" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="23,33,21,10" Grid.Row="1" SelectionChanged="FilterAuthors"/>
                <TextBlock x:Name="tblkAuthor" HorizontalAlignment="Left" Margin="18,10,0,0" Grid.Row="1" TextWrapping="Wrap" Text="Author" VerticalAlignment="Top" Height="16" Width="37"/>
                <TextBlock Name="tblkBookInfo2"></TextBlock>

                <ScrollViewer Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Grid.RowSpan="2">
                    <ItemsControl Name="selectedBooks" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"></UniformGrid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <StackPanel x:Name="spBook" MouseUp="spBook_MouseUp">
                                    <TextBlock Name="tblkBookTitle" Text ="{Binding title}"></TextBlock>
                                    <Image x:Name="imgBookImage" Source="{Binding Cover_URL }" Height="100" Width="100"></Image>
                                    <TextBlock Name="tblkBookAuthor" Text="{Binding author_name[0]}"></TextBlock>
                                </StackPanel>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>

        </TabItem>
        <TabItem x:Name="TabBookshelf">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Bookshelf"
                                  Width="25"
                                  Height="25"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Foreground="Black"/>

                    <TextBlock Text="Bookshelf"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="Black"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="170"></RowDefinition>
                    <RowDefinition Height="170"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"></materialDesign:PackIcon>

                <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" Height="50"/>
                <TextBlock x:Name="tblkShelfCartCount"  Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,41,0"/>
                <materialDesign:PackIcon Kind="Magnify" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,10,30,0"></materialDesign:PackIcon>
                <TextBox x:Name="tbxShelfSearch" Grid.Column="1" HorizontalAlignment="Left" Margin="70,0,0,0" TextWrapping="Wrap" Text="Search" VerticalAlignment="Center" Width="276" Grid.ColumnSpan="2" GotFocus="tbxShelfSearch_GotFocus" KeyUp="tbxShelfSearch_KeyUp" />

                <ListBox x:Name="lbxShelves" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="23,33,21,131" Grid.Row="1" Grid.RowSpan="2" DisplayMemberPath="ShelfName" SelectionChanged="lbxShelves_SelectionChanged"/>



               
                <TextBlock x:Name="tblkShelfNames" HorizontalAlignment="Left" Margin="18,10,0,0" Grid.Row="1" TextWrapping="Wrap" Text="My Shelves" VerticalAlignment="Top"/>

                <Button Name="btnAddShelf" Content="Add Shelf" Grid.Row="2" Click="btnAddShelf_Click"></Button>
                <Button Name="btnRemoveShelf" Content="Remove Shelf" Grid.Row="2" Margin="0,80,0,0" Click="btnRemoveShelf_Click"></Button>
                <ItemsControl Name="shelfBooks" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding ShelvedEntries}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"></UniformGrid>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel x:Name="spBook" MouseUp="spBook_MouseUp">
                                <TextBlock x:Name="tblkBookTitle" Text ="{Binding title}"></TextBlock>
                                <Image x:Name="imgBookImage" Source="{Binding Cover_URL }" Height="100" Width="100"></Image>
                                <TextBlock x:Name="tblkBookAuthor" Text="{Binding author_name[0]}"></TextBlock>

                            </StackPanel>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </TabItem>
        <TabItem x:Name="TabCheckout">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cart"
                           Width="25"
                           Height="25"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="Black"/>

                    <TextBlock Text="Checkout"
             VerticalAlignment="Center"
             FontSize="16"
             Foreground="Black"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="170"></RowDefinition>
                    <RowDefinition Height="170"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"/>
                <Label Name="lblAddress" Content="Delivery Details" Height="25" Grid.Row="1" Grid.Column="1" FontWeight="Bold" Margin="0,0,0,0" VerticalAlignment="Top"/>
                
                <Label Name="lblFullName" Content="Full Name:" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,25,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxFullName" Grid.Row="1" Grid.Column="1" Height="25" Width="160" Margin="145,24,85,0" BorderThickness="1" VerticalAlignment="Top"/>
                <Label Name="lblAddressLine1" Content="Address Line 1:" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,55,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxAddressLine1" Grid.Row="1" Grid.Column="1" Height="25" Width="160" Margin="145,54,85,0" BorderThickness="1" VerticalAlignment="Top"/>
                <Label Name="lblAddressLine2" Content="County:" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,85,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxAddressLine2" Grid.Row="1" Grid.Column="1" Height="25" Width="160" Margin="145,84,85,61" BorderThickness="1"/>
                <Label Name="lblEircode" Content="Eircode:" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,115,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxEircode" Grid.Row="1" Grid.Column="1" Height="25" Width="160" Margin="145,114,85,31" BorderThickness="1"/>

                <Label Name="lblPayment" Content="Payment Details" Grid.Row="2" Grid.Column="1" FontWeight="Bold"/>
                <Label Name="lblCardNumber" Content="Card Number: " Grid.Row="2" Grid.Column="1" Height="25" Margin="0,25,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxCardNumber" Grid.Row="2" Grid.Column="1" Height="25" Width="160" Margin="145,25,85,120" BorderThickness="1"></TextBox>
                <Label Name="lblDate" Content="Date:" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,55,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxDate" Grid.Row="2" Grid.Column="1" Height="25" Width="160" Margin="145,55,85,90" BorderThickness="1"></TextBox>
                <Label Name="lblCVV" Content="CVV:" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,85,0,0" VerticalAlignment="Top"/>
                <TextBox Name="tbxCVV" Grid.Row="2" Grid.Column="1" Height="25" Width="160" Margin="145,85,85,60" BorderThickness="1"></TextBox>
                <Button Name="btnBuyNow" Content="Buy Now" Grid.Row="2" Grid.Column="1" Margin="60,100,60,0"/>

                <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.RowSpan="2">
                    <ItemsControl Name="cartBooks" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" ItemsSource="{Binding Cart}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="1"></UniformGrid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <StackPanel Name="spBook">
                                    <TextBlock Name="tblkBookTitle" Text ="{Binding title}" HorizontalAlignment="Center"></TextBlock>
                                    <Image Name="imgBookImage" Source="{Binding Cover_URL }" Height="100" Width="100" HorizontalAlignment="Center"></Image>
                                    <TextBlock Name="tblkBookAuthor" Text="{Binding author_name[0]}" HorizontalAlignment="Center"></TextBlock>
                                    <Button Name="btnRemoveCart" Content="Remove Book" Width="250"/>
                                </StackPanel>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>


            </Grid>
        </TabItem>
        <TabItem x:Name="TabBookInfo" Width="0" Visibility="Hidden">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">

                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="2*"></RowDefinition>
                    <RowDefinition Height="3*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                
                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"></materialDesign:PackIcon>
                <TextBlock Name="tblkCount"  Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,41,0"></TextBlock>
                <materialDesign:RatingBar Grid.Row="2" Grid.Column="1" Margin="0,0,10,0" ></materialDesign:RatingBar>
                <Button Name="btnShelve" Content="Add to Bookshelf" Grid.Row="2" Grid.Column="1" Margin="0,0,10,0" Click="btnShelve_Click"></Button>
                <Button Name="btnRemove" Content="Remove from Bookshelf" Grid.Row="2" Grid.Column="1" Margin="0,70,10,0" Click="btnRemove_Click"></Button>
                <Button Name="btnAddtoCart" Content="Add to Cart" Grid.Row="2" Grid.Column="1" Margin="0,140,10,0" Click="btnAddtoCart_Click"></Button>


                <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.RowSpan="2">
                    <StackPanel>
                        <TextBlock Name="tblkTitle" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center"></TextBlock>
                        <Image Name="imgCover" Grid.Row="1" Grid.Column="0" Width="100px" Height="100px" HorizontalAlignment="Center"></Image>
                        <TextBlock Name="tblkBookInfo" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center"></TextBlock>
                        <TextBlock Name="tblkPrice" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" Margin="0,25,0,0"></TextBlock>
                        <TextBlock Name="tblkPublished" Grid.Row="2" Grid.Column="0" Margin="0,50,0,0" HorizontalAlignment="Center"></TextBlock>
                        <TextBlock Name="tblkEditions" Grid.Row="2" Grid.Column="0" Margin="0,75,0,0" HorizontalAlignment="Center"></TextBlock>
                        <TextBlock Name="tblkLanguages" Grid.Row="2" Grid.Column="0" Margin="0,100,0,0" HorizontalAlignment="Center"></TextBlock>
                        <TextBlock Name="tblkDescription" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left" Margin="0,15,0,0"></TextBlock>
                    </StackPanel>
                </ScrollViewer>
                

            </Grid>
        </TabItem>

    </TabControl>


</Window>

    
        