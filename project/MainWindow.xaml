<Window x:Name="MainWindow1" x:Class="project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:project"
        mc:Ignorable="d"
        Title="Home" Height="450" Width="800" MinHeight="400" MinWidth="600" Loaded="MainWindow1_Loaded"
        Background="RosyBrown">
    <TabControl x:Name="MyControl" TabStripPlacement="Bottom">
        <TabItem x:Name="TabHome">
            <TabItem.Header>

                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Home"
                                             Width="25"
                                             Height="25"
                                             Foreground="Black"
                                             ></materialDesign:PackIcon>
                    <TextBlock Text="Home"
                     VerticalAlignment="Center"
                     FontSize="16"
                     Foreground="Black"/>
                </StackPanel>
            </TabItem.Header>
            <Grid Name="myGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="75"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200*"></ColumnDefinition>
                    <ColumnDefinition Width="300*"></ColumnDefinition>
                    <ColumnDefinition Width="300*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1" Grid.Column="0" Grid.RowSpan="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Name="lblAuthors"  HorizontalAlignment="Left" Grid.Row="0"  Content="Authors" VerticalAlignment="Top" FontWeight="Bold" ></Label>
                    <ScrollViewer Grid.Row="1">
                        <ListBox x:Name="lbxAuthor" ItemsSource="{Binding AuthorNames}" Grid.Row="1" Background="GhostWhite" SelectionChanged="FilterAuthors"/>
                    </ScrollViewer>
                   
                    
                </Grid>
                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"/>
                <TextBlock Name="tblkCartCount" Text="{Binding CartCount}" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,41,0"/>
                <TextBlock Name="tblkLogin" Text="Logout" Grid.Row="0" Grid.Column="2" Width="80" Height="25" PreviewMouseDown="tblkLogin_PreviewMouseDown"/>
                <TextBox Name="tbxSearch" Background="GhostWhite" Foreground="Black" Grid.Column="1" HorizontalAlignment="Left" Margin="70,0,0,0" TextWrapping="Wrap" Text="Search" VerticalAlignment="Center" Width="276" Grid.ColumnSpan="2" GotFocus="tbxSearch_GotFocus" KeyDown="tbxSearch_KeyDown"/>
                <materialDesign:PackIcon Kind="Magnify" Grid.Column="2" Margin="51,0,0,0" VerticalAlignment="Center"/>
                <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Foreground="Black" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Width="50" Height="50"/>
                <Label Name="lblAppNameHome" Content="My Little Library" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"></Label>

                <ScrollViewer Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Grid.RowSpan="2">
                    <ItemsControl Name="selectedBooks" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"></UniformGrid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>


                            <DataTemplate>
                                <Border BorderBrush="GhostWhite" BorderThickness="1" CornerRadius="8" Margin="5,5,5,5" Background="GhostWhite">
                                    <StackPanel x:Name="spBook" MaxHeight="180" MouseUp="spBook_MouseUp" >
                                        <TextBlock Name="tblkBookTitle" Text ="{Binding title}" TextWrapping="Wrap"></TextBlock>
                                        <Image x:Name="imgBookImage" Source="{Binding Cover_URL }" Height="100" Width="100"></Image>
                                        <TextBlock Name="tblkBookAuthor" Text="{Binding author_name[0]}"></TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>

                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>

        </TabItem>
        <TabItem x:Name="TabBookshelf">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Bookshelf"
                                  Width="25"
                                  Height="25"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Foreground="Black"/>

                    <TextBlock Text="Bookshelf"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="Black"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="75"></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition ></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200*"></ColumnDefinition>
                    <ColumnDefinition Width="300*"></ColumnDefinition>
                    <ColumnDefinition Width="300*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1" Grid.Column="0" Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Name="lblShelfNames" FontWeight="Bold" HorizontalAlignment="Left"  Grid.Row="0"  Content="My Shelves" VerticalAlignment="Top"></Label>
                    <ScrollViewer Grid.Row="1" Grid.RowSpan="2">
                        <ListBox x:Name="lbxShelves" ItemsSource="{Binding AllShelves}"  Grid.Row="1" Grid.RowSpan="2" DisplayMemberPath="ShelfName" Background="GhostWhite" SelectionChanged="lbxShelves_SelectionChanged"/>
                        
                    </ScrollViewer>
                    
                    <Button Name="btnAddShelf" Content="Add Shelf" Grid.Row="3" Width="150" Click="btnAddShelf_Click" ></Button>
                    <Button Name="btnRemoveShelf" Content="Remove Shelf" Grid.Row="4" Width="150"  Click="btnRemoveShelf_Click"></Button>
                </Grid>
                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"></materialDesign:PackIcon>

                <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Foreground="Black" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Width="50" Height="50"/>
                <Label Name="lblAppNameShelf" Content="My Little Library" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"></Label>
                <TextBlock x:Name="tblkShelfCartCount" Text="{Binding CartCount}"  Grid.Row="0" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,41,0"/>
                <materialDesign:PackIcon Kind="Magnify" Grid.Column="2" Margin="51,0,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="tbxShelfSearch"  Background="GhostWhite" Foreground="Black" Grid.Column="1" HorizontalAlignment="Left" Margin="70,0,0,0" TextWrapping="Wrap" Text="Search" VerticalAlignment="Center" Width="276" Grid.ColumnSpan="2" GotFocus="tbxShelfSearch_GotFocus" KeyUp="tbxShelfSearch_KeyUp" />

                




                

               
                <ScrollViewer Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Grid.RowSpan="2">
                    <ItemsControl Name="shelfBooks" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"></UniformGrid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="GhostWhite" BorderThickness="1" CornerRadius="8" Margin="5,5,5,5" Background="GhostWhite">
                                    <StackPanel x:Name="spBook" MaxHeight="180" MouseUp="spBook_MouseUp">
                                        <TextBlock x:Name="tblkBookTitle" Text ="{Binding title}" TextWrapping="Wrap"></TextBlock>
                                        <Image x:Name="imgBookImage" Source="{Binding Cover_URL}" Height="100" Width="100"></Image>
                                        <TextBlock x:Name="tblkBookAuthor" Text="{Binding author_name[0]}"></TextBlock>

                                    </StackPanel>
                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </TabItem>
        <TabItem x:Name="TabCheckout">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cart"
                           Width="25"
                           Height="25"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="Black"/>

                    <TextBlock Text="Checkout"
             VerticalAlignment="Center"
             FontSize="16"
             Foreground="Black"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition>
                    </ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.Column="1" DataContext="{Binding CurrentUser}">
                <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Name="lblAddress" Content="Delivery Details" Height="25" Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="0,0,0,0" VerticalAlignment="Top"/>
                    <Label Name="lblFullName" Content="Full Name:" Grid.Row="1" Grid.Column="0" Height="25" HorizontalAlignment="Left"/>
                    <Label Name="lblAddressLine1"  Content="Address Line 1:" Grid.Row="2" Grid.Column="0" Height="25" VerticalAlignment="Center"/>
                    <Label Name="lblAddressLine2" Content="County:" Grid.Row="3" Grid.Column="0" Height="25" VerticalAlignment="Center"/>
                    <Label Name="lblEircode" Content="Eircode:" Grid.Row="4" Grid.Column="0" Height="25" VerticalAlignment="Center"/>
                    <TextBlock Name="tblkFullName" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1" Grid.Column="1" Height="25" Width="160" Background="GhostWhite"/>
                    <TextBox Name="tbxAddressLine1"  Text="{Binding AddressLineOne}" Grid.Row="2" Grid.Column="1" Height="25" Width="160" BorderThickness="1" VerticalAlignment="Center" Background="GhostWhite"/>
                    <TextBox Name="tbxAddressLine2" Text="{Binding AddressLineTwo}" Grid.Row="3"  Grid.Column="1" Height="25" Width="160"  BorderThickness="1" Background="GhostWhite" VerticalAlignment="Center"/>
                    <TextBox Name="tbxEircode" Text="{Binding Eircode}" Grid.Row="4" Grid.Column="1" Height="25" Width="160" BorderThickness="1" Background="GhostWhite"/>



                </Grid>

                <Grid Grid.Row="1" Grid.Column="1" DataContext="{Binding CurrentUser}">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Label Name="lblPayment" Content="Payment Details" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                    <Label Name="lblCardNumber" Content="Card Number: " Grid.Row="1" Grid.Column="0" Height="25" VerticalAlignment="Center"/>
                    <Label Name="lblDate" Content="Date:" Grid.Row="2" Grid.Column="0" Height="25" VerticalAlignment="Center"/>
                    <Label Name="lblCVV" Content="CVV:" Grid.Row="3" Grid.Column="0" Height="25" VerticalAlignment="Center"/>
                    
                    <TextBox Name="tbxCardNumber" Text="{Binding CardNumber}" Grid.Row="1" Grid.Column="1" Height="25" Width="160" BorderThickness="1" Background="GhostWhite"></TextBox>
                    <TextBox Name="tbxDate" Grid.Row="2" Grid.Column="1" Height="25" Width="160" BorderThickness="1" Background="GhostWhite"></TextBox>
                    <TextBox Name="tbxCVV" Text="{Binding CVV}" Grid.Row="3" Grid.Column="1" Height="25" Width="160" BorderThickness="1" Background="GhostWhite"></TextBox>

                    <Button Name="btnBuyNow" Content="Buy Now" Grid.Row="4" Grid.Column="1" Click="btnBuyNow_Click" />
                </Grid>

                <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Label Name="lblTotal" Content="Total: €" FontWeight="Bold" Grid.Row="0" Grid.Column="0"  VerticalAlignment="Top" HorizontalAlignment="Right"/>
                    <TextBlock Name="tblkTotalCost" Text="{Binding Total}" FontWeight="Bold" Grid.Row="0" Grid.Column="1" Height="30" Width="75" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,-2,0,0"/>

                    <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">

                        <ItemsControl Name="cartBooks"  ItemsSource="{Binding Cart}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"></UniformGrid>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="GhostWhite" BorderThickness="1" CornerRadius="8" Margin="5,5,5,5" Background="GhostWhite">
                                        <StackPanel Name="spBook" >
                                            <TextBlock Name="tblkBookTitle" Text ="{Binding title}" HorizontalAlignment="Center"></TextBlock>
                                            <Image Name="imgBookImage" Source="{Binding Cover_URL }" Height="100" Width="100" HorizontalAlignment="Center"></Image>
                                            <TextBlock Name="tblkBookAuthor" Text="{Binding author_name[0]}" HorizontalAlignment="Center"></TextBlock>
                                            <TextBlock Name="tblkPrice" Text="{Binding price, StringFormat=€ {0}}" HorizontalAlignment="Center"/>
                                            <Button Name="btnRemoveCart" Content="Remove Book" Width="250" Click="btnRemoveCart_Click"/>
                                        </StackPanel>
                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

               

                


            </Grid>
        </TabItem>
        <TabItem x:Name="TabBookInfo" Width="0" Visibility="Hidden">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">

                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="2*"></RowDefinition>
                    <RowDefinition Height="3*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="1">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Label Name="lblRate" Content="Add a rating?" FontSize="16" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top"></Label>
                    <materialDesign:RatingBar Grid.Row="1" Grid.Column="0" ></materialDesign:RatingBar>
                </Grid>

                <materialDesign:PackIcon Kind="Cart" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Margin="0,10,20,0" MouseUp="PackIcon_MouseUp"></materialDesign:PackIcon>
                <TextBlock Name="tblkCount" Text="{Binding CartCount}" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,9,41,0"></TextBlock>
               
                <Button Name="btnShelve" Content="Add to Bookshelf" Grid.Row="2" Grid.Column="1" Margin="0,0,10,0" Width="200" Click="btnShelve_Click"></Button>
                <Button Name="btnRemove" Content="Remove from Bookshelf" Grid.Row="2" Grid.Column="1" Margin="0,70,10,0"  Width="200" Click="btnRemove_Click"></Button>
                <Button Name="btnAddtoCart" Content="Add to Cart" Grid.Row="2" Grid.Column="1" Margin="0,140,10,0"  Width="200" Click="btnAddtoCart_Click"></Button>


                <ScrollViewer Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" DataContext="{Binding SelectedBook}">
                    <Border BorderBrush="GhostWhite" BorderThickness="1" CornerRadius="8" Margin="5,5,5,5" Background="GhostWhite">
                        <StackPanel Background="GhostWhite" Margin="5,5,5,5">
                            <TextBlock Name="tblkTitle" Text="{Binding title}" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center"></TextBlock>
                            <Image Name="imgCover" Grid.Row="1" Grid.Column="0" Width="100px" Height="100px" HorizontalAlignment="Center"></Image>
                            <TextBlock Name="tblkBookInfo" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center"></TextBlock>
                            <TextBlock Name="tblkPrice" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" Margin="0,15,0,0"></TextBlock>
                            <TextBlock Name="tblkPublished" Text="{Binding first_publish_year}" Grid.Row="2" Grid.Column="0" Margin="0,15,0,0" HorizontalAlignment="Center"></TextBlock>
                            <TextBlock Name="tblkEditions" Grid.Row="2" Grid.Column="0" Margin="0,15,0,0" HorizontalAlignment="Center"></TextBlock>
                            <TextBlock Name="tblkLanguages" Grid.Row="2" Grid.Column="0" Margin="0,15,0,0" HorizontalAlignment="Center" MaxWidth="500" TextWrapping="Wrap"></TextBlock>
                            <TextBlock Name="tblkDescription" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left" Margin="0,15,0,0" MaxWidth="500" TextWrapping="Wrap"></TextBlock>
                        </StackPanel>
                    </Border>
                </ScrollViewer>


            </Grid>
        </TabItem>

    </TabControl>


</Window>

    
        